{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Study Tracker",
  "version": "0.1.0",
  "identifier": "com.studytracker",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Kaelie",
        "width": 980,
        "height": 720,
        "minWidth": 380,
        "minHeight": 560,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    },
    "withGlobalTauri": false
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "appimage", "dmg"],
    "icon": ["icons/icon.png", "icons/icon.ico"]
  }
}
